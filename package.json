{
  "name": "mindoodb-app-teamedit",
  "version": "1.0.0",
  "description": "Collaborative markdown editor sample app for MindooDB Haven",
  "license": "ISC",
  "author": "Mindoo GmbH",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "vite --port 4206",
    "dev:local": "LOCAL_MINDOODB=1 vite --port 4206",
    "build": "vue-tsc --noEmit && vite build",
    "build:local": "LOCAL_MINDOODB=1 vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/rubik": "^5.2.8",
    "@milkdown/crepe": "^7.17.1",
    "@primeuix/styled": "^0.7.4",
    "@primeuix/themes": "^2.0.3",
    "dompurify": "^3.4.1",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.14.0",
    "mindoodb-app-sdk": "0.0.16",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
